# ==========================================
# Monorepo Gitignore Configuration
# ==========================================

# Editor & System Files
.vscode/
.idea/
.DS_Store
*.suo
*.swp
*.lock

# ==========================================
# Backend Configuration (Python / LaTeX)
# ==========================================
**/__pycache__/
**/*.py[cod]
**/*$py.class
backend/.Python
backend/build/
backend/dist/
backend/sdist/
backend/wheels/
backend/*.egg-info/
backend/*.egg

# Virtual environments
backend/.venv/
backend/venv/
backend/env/

# Environment configurations
backend/.env
backend/.env.*

# Input documents & local caches
backend/*.pdf
backend/jd.txt
backend/data/
!backend/data/.gitkeep
backend/pdf-forge-exports/

# ==========================================
# Frontend Configuration (React / Vite)
# ==========================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.eslintcache
frontend/package-lock.json

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
